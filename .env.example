# =============================================================================
# Joints.AI — environment variables
# Copy this file to `.env.local` for local dev, or paste the values into your
# Vercel / Netlify project settings for production.
# =============================================================================

# --- Supabase (auth + database) -----------------------------------------------
# https://supabase.com  →  Project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only — DO NOT prefix with NEXT_PUBLIC_. Used by API routes that
# need to bypass RLS (e.g. insert feedback rows).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Python backend (FastAPI) -------------------------------------------------
# In local dev this points at http://localhost:8000. In production, point it
# at your deployed backend (Render, Railway, Fly.io, etc.) over HTTPS.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# --- LLM provider (optional, server-side) -------------------------------------
# Used by API routes that call an LLM directly. If your Python backend owns all
# LLM calls, this can stay unset.
OPENAI_API_KEY=sk-...
