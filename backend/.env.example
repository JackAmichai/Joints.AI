# Copy to backend/.env and fill in.
# Every value listed here has a safe default in app/config.py — you only need
# to override what you actually use.

# --- HTTP service ---
TECHPHYSIO_HOST=127.0.0.1
TECHPHYSIO_PORT=8000
TECHPHYSIO_CORS_ORIGINS=http://localhost:3000

# --- Storage (SQLite for dev, swap for Postgres in prod) ---
TECHPHYSIO_DB_URL=sqlite:///./techphysio.db
TECHPHYSIO_FILE_STORAGE_DIR=./uploads

# --- Vector store ---
TECHPHYSIO_CHROMA_DIR=./chroma
TECHPHYSIO_CHROMA_COLLECTION=techphysio_exercises

# --- LLM / VLM (Nemotron or compatible local model) ---
# Leave blank to run in stubbed mode — the Extractor will pass through the
# user's structured input without invoking a model. The retriever still runs.
TECHPHYSIO_LLM_ENDPOINT=
TECHPHYSIO_LLM_API_KEY=
TECHPHYSIO_LLM_MODEL=nemotron-3-8b-safety
TECHPHYSIO_VLM_ENDPOINT=
TECHPHYSIO_VLM_MODEL=

# --- Clinical review queue ---
# If set, drafted plans POST to this webhook for a clinician to review.
TECHPHYSIO_CLINICIAN_WEBHOOK_URL=

# --- Operator ---
TECHPHYSIO_LOG_LEVEL=INFO
